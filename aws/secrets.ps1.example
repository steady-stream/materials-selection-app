# aws/secrets.ps1.example
#
# Copy this file to aws/secrets.ps1 and fill in the real values.
# aws/secrets.ps1 is in .gitignore and will never be committed.
#
# Used by: aws/setup-prod-infrastructure.ps1

# Salesforce OAuth credentials
$SF_CLIENT_ID     = "REPLACE_WITH_SF_CLIENT_ID"
$SF_CLIENT_SECRET = "REPLACE_WITH_SF_CLIENT_SECRET"
$SF_USERNAME      = "REPLACE_WITH_SF_USERNAME"
$SF_PASSWORD      = "REPLACE_WITH_SF_PASSWORD_PLUS_TOKEN"
$SF_AUTH_URL      = "https://login.salesforce.com/services/oauth2/token"
$SF_INSTANCE_URL  = "https://megapros.my.salesforce.com"

# Azure / SharePoint credentials (for main Lambda SharePoint integration)
$AZURE_CLIENT_ID        = "REPLACE_WITH_AZURE_CLIENT_ID"
$AZURE_CLIENT_SECRET    = "REPLACE_WITH_AZURE_CLIENT_SECRET"
$AZURE_TENANT_ID        = "REPLACE_WITH_AZURE_TENANT_ID"
$SHAREPOINT_SITE_URL    = "REPLACE_WITH_SHAREPOINT_SITE_URL"
$SHAREPOINT_LIBRARY     = "Shared Documents"
$SHAREPOINT_BASE_FOLDER = "Materials Selection"
